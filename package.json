{
  "name": "@luban-ui/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "nx run @luban-ui/luban-ui:dev",
    "storybook": "pnpm exec storybook dev -p 6006",
    "build-storybook": "pnpm exec storybook build",
    "test": "nx test @luban-ui/luban-ui",
    "test:coverage": "nx run-many --target=test --all -- --coverage",
    "test:e2e": "cd apps/luban-ui-e2e && npx playwright test",
    "test:e2e:install": "cd apps/luban-ui-e2e && npx playwright install chrome",
    "test:base": "nx test luban-base",
    "test:base:component": "cd packages/luban-base && vitest run -c vitest.component.config.mts",
    "test:lowcode": "nx test luban-low-code",
    "test:lowcode:component": "cd packages/luban-low-code && vitest run -c vitest.component.config.mts",
    "test:lowcode:e2e": "cd packages/luban-low-code && vitest run -c vitest.e2e.config.mts",
    "lint": "nx run-many --target=lint --all && prettier --check . && stylelint \"**/*.{css,scss}\"",
    "lint:fix": "nx run-many --target=lint --all --fix && prettier --write . && stylelint \"**/*.{css,scss}\" --fix",
    "depcruise": "depcruise apps packages --config",
    "prepare": "husky",
    "version:packages": "pnpm exec nx run-many --target=version --projects=luban-base,luban-low-code",
    "release:nx:latest": "PUBLISH_TAG=latest pnpm exec nx run-many --target=publish --projects=luban-base,luban-low-code --skip-nx-cache",
    "release:nx:beta": "PUBLISH_TAG=beta pnpm exec nx run-many --target=publish --projects=luban-base,luban-low-code --skip-nx-cache"
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "eslint --fix"
    ],
    "*.{css,scss,vue}": [
      "stylelint --fix"
    ],
    "*.{ts,tsx,vue,css,scss,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "private": true,
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^9.8.0",
    "@nx/cypress": "22.5.4",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/storybook": "^22.5.4",
    "@nx/vite": "22.5.4",
    "@nx/vitest": "22.5.4",
    "@nx/vue": "22.5.4",
    "@nx/web": "22.5.4",
    "@nx/workspace": "22.5.4",
    "@playwright/test": "^1.49.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/vue3": "^8.6.14",
    "@storybook/vue3-vite": "^8.6.14",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "20.19.9",
    "@typescript-eslint/parser": "^8.40.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.0",
    "@vitest/ui": "^4.0.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "css-loader": "^7.0.0",
    "cypress": "^15.8.0",
    "dependency-cruiser": "^16.0.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-cypress": "^3.5.0",
    "eslint-plugin-vue": "^9.16.1",
    "husky": "^9.0.0",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "lint-staged": "^15.0.0",
    "nx": "22.5.4",
    "postcss": "^8.5.8",
    "postcss-html": "^1.7.0",
    "prettier": "~3.6.2",
    "sass": "1.98.0",
    "storybook": "^8.6.14",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.0",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^2.2.8"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@storybook/*",
        "storybook"
      ],
      "allowAny": [
        "sass"
      ]
    }
  }
}
