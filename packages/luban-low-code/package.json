{
  "name": "@luban-low-code/luban-low-code",
  "version": "0.0.15",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "name": "luban-low-code",
    "tags": [
      "lib:low-code",
      "type:library"
    ],
    "targets": {
      "version": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "packages/luban-low-code",
          "command": "pnpm version patch --no-git-tag-version"
        }
      },
      "publish": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "build",
          "test"
        ],
        "options": {
          "cwd": "packages/luban-low-code",
          "command": "npm publish --access public --tag ${PUBLISH_TAG:-latest}"
        }
      }
    }
  },
  "dependencies": {
    "sortablejs": "^1.15.3",
    "vue": "^3.5.13",
    "vitest": "^4.0.0",
    "@vitejs/plugin-vue": "^6.0.1"
  }
}
