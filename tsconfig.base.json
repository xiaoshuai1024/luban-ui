{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@luban-ui/source"],
    "paths": {
      "@luban-ui/button": ["packages/components/button/src/index.ts"],
      "@luban-ui/types": ["packages/types/src/index.ts"],
      "@luban-ui/theme": ["packages/theme/src/index.ts"]
    }
  }
}
